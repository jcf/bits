@import "tailwindcss";
@source "../src/**/*.clj";

@view-transition {
  navigation: auto;
}

{% for font in fonts %}@font-face {
  font-family: '{{font.family}}';
  font-style: {{font.style}};
  font-weight: {{font.weight}};
  font-display: swap;
  src: url('{{font.url}}') format('woff2');
}

{% endfor %}
@theme {
  --font-serif: 'DM Serif Display', Georgia, serif;
  --font-sans: 'DM Sans', system-ui, sans-serif;
  --font-mono: 'JetBrains Mono', ui-monospace, monospace;

{% for color in colors %}  --color-{{color.name}}: {{color.value}};
{% endfor %}}

@layer components {
  .cursor {
    @apply absolute pointer-events-none z-50;
    transition: left 50ms ease-out, top 50ms ease-out;
  }

  .bg-gradient-banner {
    background: linear-gradient(135deg,
      var(--color-banner-start) 0%,
      var(--color-banner-mid) 50%,
      var(--color-surface) 100%);
  }

  .bg-gradient-locked {
    background: linear-gradient(135deg,
      var(--color-locked-start) 0%,
      var(--color-locked-mid) 50%,
      var(--color-locked-end) 100%);
  }

  .form-shake {
    animation: form-shake 400ms ease-out;
  }
}

@keyframes form-shake {
  0%, 100% { transform: translateX(0); }
  10% { transform: translateX(-4px); }
  30% { transform: translateX(3px); }
  50% { transform: translateX(-2px); }
  70% { transform: translateX(1px); }
  90% { transform: translateX(-0.5px); }
}

@keyframes form-reject-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.7; }
}

@media (prefers-reduced-motion: reduce) {
  .form-shake {
    animation: form-reject-pulse 300ms ease-out;
  }
}
