{:paths   ["resources" "src"]
 :license {:name "BUSL-1.1"
           :url  "https://spdx.org/licenses/BUSL-1.1.html"}
 :deps
 {babashka/fs                                                     {:mvn/version "0.5.33"}
  babashka/process                                                {:mvn/version "0.6.25"}
  buddy/buddy-core                                                {:mvn/version "1.12.0-430"}
  buddy/buddy-hashers                                             {:mvn/version "2.0.167"}
  buddy/buddy-sign                                                {:mvn/version "3.6.1-359"}
  camel-snake-kebab/camel-snake-kebab                             {:mvn/version "0.4.3"}
  ch.qos.logback/logback-classic                                  {:mvn/version "1.5.35"}
  clojure.java-time/clojure.java-time                             {:mvn/version "1.4.3"}
  com.aayushatharva.brotli4j/brotli4j                             {:mvn/version "1.23.0"}
  com.cnuernber/charred                                           {:mvn/version "1.039"}
  com.datomic/peer                                                {:mvn/version "1.0.7622"}
  com.github.seancorfield/honeysql                                {:mvn/version "2.7.1390"}
  com.github.seancorfield/next.jdbc                               {:mvn/version "1.3.1118"}
  com.github.steffan-westcott/clj-otel-api                        {:mvn/version "0.2.10"}
  com.google.guava/guava                                          {:mvn/version "33.6.0-jre"}
  com.stuartsierra/component                                      {:mvn/version "1.2.0"}
  com.taoensso/nippy                                              {:mvn/version "3.6.2"}
  com.zaxxer/HikariCP                                             {:mvn/version "7.1.0" :exclusions [org.slf4j/slf4j-api]}
  dev.jcf/winnow                                                  {:mvn/version "1.2.0"}
  dev.weavejester/medley                                          {:mvn/version "1.10.0"}
  dev.weavejester/ragtime.core                                    {:mvn/version "0.12.1"}
  dev.weavejester/ragtime.next-jdbc                               {:mvn/version "0.12.1"}
  funcool/promesa                                                 {:mvn/version "12.0.0"}
  hato/hato                                                       {:mvn/version "1.0.0"}
  hiccup/hiccup                                                   {:mvn/version "2.0.0"}
  http-kit/http-kit                                               {:mvn/version "2.9.0-beta3"}
  inflections/inflections                                         {:mvn/version "0.15.0"}
  io.github.metabase/mr-worldwide                                 {:git/sha   "67afb183cd6c5879b9f4a7fc2f75a1e42b4af1c3"
                                                                   :deps/root "mr-worldwide"}
  io.netty/netty-buffer                                           {:mvn/version "4.2.15.Final"}
  io.opentelemetry.instrumentation/opentelemetry-java-http-client {:mvn/version "2.29.0-alpha"}
  io.opentelemetry.instrumentation/opentelemetry-jdbc             {:mvn/version "2.29.0-alpha"}
  io.pedestal/pedestal.log                                        {:mvn/version "0.8.1"}
  io.replikativ/hasch                                             {:mvn/version "0.3.94"}
  lambdaisland/uri                                                {:mvn/version "1.19.155"}
  metosin/reitit                                                  {:mvn/version "0.10.0"}
  org.apache.commons/commons-lang3                                {:mvn/version "3.20.0"}
  org.babashka/cli                                                {:mvn/version "0.11.74"}
  org.clojars.pjlegato/clansi                                     {:mvn/version "1.3.0"}
  org.clojure/clojure                                             {:mvn/version "1.12.5"}
  org.clojure/core.async                                          {:mvn/version "1.9.865"}
  org.jgroups/jgroups                                             {:mvn/version "5.5.5.Final"}
  org.postgresql/postgresql                                       {:mvn/version "42.7.11"}
  org.tcrawley/conformity                                         {:mvn/version "0.6.0"}
  ring/ring-core                                                  {:mvn/version "2.0.0-alpha1"}
  ring/ring-headers                                               {:mvn/version "0.4.0"}
  ring/ring-mock                                                  {:mvn/version "0.6.2"}
  ring/ring-spec                                                  {:mvn/version "0.0.4"}}

 :aliases
 {:cli
  {:jvm-opts ["--enable-native-access=ALL-UNNAMED"]}

  :darwin-aarch64
  {:extra-deps
   {com.aayushatharva.brotli4j/native-osx-aarch64 {:mvn/version "1.23.0"}}}

  :linux-aarch64
  {:extra-deps
   {com.aayushatharva.brotli4j/native-linux-aarch64 {:mvn/version "1.23.0"}}}

  :linux-x86_64
  {:extra-deps
   {com.aayushatharva.brotli4j/native-linux-x86_64 {:mvn/version "1.23.0"}}}

  :dev
  {:jvm-opts    ["-XX:+UseG1GC"
                 "-XX:MaxGCPauseMillis=100"
                 "-Xms1g"
                 "-Xmx16g"
                 "--enable-native-access=ALL-UNNAMED"]
   :extra-paths ["dev" "dev-resources"]
   :extra-deps
   {com.stuartsierra/component.repl {:mvn/version "1.0.0"}
    etaoin/etaoin                   {:mvn/version "1.1.43"}
    org.clojure/test.check          {:mvn/version "1.1.3"}
    org.clojure/tools.namespace     {:mvn/version "1.5.1"}
    selmer/selmer                   {:mvn/version "1.13.4"}}}

  :logging
  {:jvm-opts ["-Dclojure.tools.logging.factory=clojure.tools.logging.impl/slf4j-factory"]}

  :nrepl
  {:jvm-opts ["-Djdk.attach.allowAttachSelf"]
   :extra-deps
   {cider/cider-nrepl             {:mvn/version "0.59.0"}
    com.cemerick/pomegranate      {:mvn/version "1.1.0"}
    org.tcrawley/dynapath         {:mvn/version "1.1.0"}
    refactor-nrepl/refactor-nrepl {:mvn/version "3.13.0"}}}

  :test
  {;; We need to send requests with custom `Host` headers to test realms, and by
   ;; default the JDK does not allow one to set this header.
   :jvm-opts    ["-Djdk.httpclient.allowRestrictedHeaders=host"]
   :extra-paths ["test" "test-resources"]
   :extra-deps
   {etaoin/etaoin              {:mvn/version "1.1.43"}
    invetica/spec              {:mvn/version "0.5.0"}
    nubank/matcher-combinators {:mvn/version "3.10.0"}
    org.clj-commons/hickory    {:mvn/version "0.7.7"}}}

  :otel
  {:jvm-opts ["-Dotel.java.global-autoconfigure.enabled=true"]
   :extra-deps
   {com.github.steffan-westcott/clj-otel-sdk-extension-autoconfigure {:mvn/version "0.2.10"}
    io.opentelemetry/opentelemetry-sdk-extension-autoconfigure       {:mvn/version "1.63.0"}
    io.opentelemetry/opentelemetry-exporter-otlp                     {:mvn/version "1.63.0"}}}

  :build
  {:deps       {io.github.clojure/tools.build         {:git/tag "v0.10.14" :git/sha "1176afd"}
                io.github.metabase/mr-worldwide.build {:git/url   "https://github.com/metabase/mr-worldwide.git"
                                                       :git/sha   "67afb183cd6c5879b9f4a7fc2f75a1e42b4af1c3"
                                                       :deps/root "mr-worldwide.build"}}
   :ns-default build}

  :runner
  {:extra-deps {lambdaisland/kaocha {:mvn/version "1.91.1392"}}
   :main-opts  ["-m" "kaocha.runner"]}}}
